{
  "name": "subastar-backend",
  "version": "0.1.0",
  "private": true,
  "description": "API REST de SubastAR (Node + Express + TypeScript + PostgreSQL)",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --watch src --exit-child src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:reset":  "ts-node-dev --transpile-only --no-notify src/scripts/dbReset.ts",
    "seed:admin": "ts-node-dev --transpile-only --no-notify src/scripts/seedAdmin.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/ws": "^8.5.12",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
