# Server
PORT=4000
NODE_ENV=development

# Database: PostgreSQL (queries SQL planas, sin ORM)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=subastar
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=10

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Fines (multas)
FINE_PERCENTAGE=10
FINE_DEADLINE_HOURS=72
